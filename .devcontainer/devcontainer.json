{
  "name": "Go (Babylon Tower)",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "moby": false
    }
  },
  "hostNetwork": true,
  "runArgs": [
    "--cap-add=NET_ADMIN",
    "--cap-add=NET_RAW",
    "--cap-add=NET_BIND_SERVICE",
    "--device=/dev/dri",
    "--device=/dev/video0",
    "--device=/dev/snd",
    "-e", "GDK_BACKEND=x11",
    "-e", "SDL_VIDEODRIVER=x11"
  ],
  "postCreateCommand": "sudo service avahi-daemon start 2>/dev/null || true && echo 'export PKG_CONFIG_PATH=/usr/lib/x86_64-linux-gnu/pkgconfig:/usr/share/pkgconfig:$PKG_CONFIG_PATH' >> ~/.bashrc",
  "postStartCommand": "sudo service avahi-daemon start 2>/dev/null || echo 'Note: avahi-daemon not available, mDNS may not work'",
  "customizations": {
    "vscode": {
      "extensions": [
        "golang.go",
        "ms-vscode.cpptools",
        "rust-lang.rust-analyzer"
      ],
      "settings": {
        "go.buildTags": "",
        "go.toolsEnvVars": {
          "CGO_ENABLED": "1"
        },
        "terminal.integrated.env.linux": {
          "PKG_CONFIG_PATH": "/usr/lib/x86_64-linux-gnu/pkgconfig:/usr/share/pkgconfig"
        }
      }
    }
  }
}
